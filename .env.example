# Database
DATABASE_URL="postgresql://username:password@localhost:5432/trichome_db?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/trichome_db?schema=public"

NODE_ENV=development

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Public site URL - used for canonical links, sitemap, robots.txt, and JSON-LD
NEXT_PUBLIC_SITE_URL="https://www.trichomesshop.com"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

ADMIN_PASSWORD=""

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Paystack API Credentials
# Get these from your Paystack dashboard: https://dashboard.paystack.com/#/settings/developer
# Use pk_test_xxx / sk_test_xxx for test mode, pk_live_xxx / sk_live_xxx for production
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""

# Email (SMTP)
SMTP_SERVER=""
SMTP_PORT=587
LOGIN=""
SMTP_PASSWORD=""
EMAIL_FROM=""

# Comma-separated list of emails to notify when a new order is placed
# (in addition to all ADMIN/STAFF user accounts, which are notified automatically)
ADMIN_NOTIFICATION_EMAIL=""

NEXT_PUBLIC_WHATSAPP_NUMBER=""

# Terminal Africa Tship Shipping API — optional. If TERMINAL_SECRET_KEY is
# unset, checkout falls back to the static per-state rate table in
# src/lib/shipping/calculate-shipping.ts. Get keys from the Terminal Africa
# dashboard's settings tab (requires account KYC to be approved first).
TERMINAL_SECRET_KEY=""
# Not currently used by this app's server-side rate quoting — kept for a
# possible future client-side integration.
TERMINAL_PUBLIC_KEY=""
# Terminal Africa uses different hostnames for sandbox vs. production.
# Defaults to the sandbox host in code if unset.
TERMINAL_AFRICA_BASE_URL=""
