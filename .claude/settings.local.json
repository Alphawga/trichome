            "timeout": 15,
            "statusMessage": "edit-check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alpha/trichome/.claude/hooks/learning-checkpoint.sh",
            "timeout": 15,
            "statusMessage": "learning-checkpoint"
          }
        ]
      }
    ]
  }
